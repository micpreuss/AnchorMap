# Docker build context — keep it small. The image bakes in only the engine + figures + the
# self-contained synthetic fixture (see docker/Dockerfile). Everything below is irrelevant to the
# build and would only bloat the context / leak host artifacts.

# Vendored scaffold — its own git repo, not part of AnchorMap
claude-science-scaffold/

# VCS / planning / validation harness (not needed at runtime)
.git/
.gitignore
.agents/
.claude/
validation/

# Engine outputs (regenerated by the build-time self-test inside the image)
results/

# Tests: keep only the synthetic fixtures the Dockerfile COPYs explicitly; exclude the rest
tests/run_tests.R
tests/test_phase2.R
tests/test_phase3.R
tests/fixtures/make_synthetic_ldsc.R
tests/fixtures/synthetic_ldsc.rds
tests/fixtures/synthetic_ldsc_negh2.rds

# Editor / OS / R session cruft
.DS_Store
.Rhistory
.RData
.Rapp.history
.Rproj.user/
*_cache/
*~
.idea/
AnchorMap.code-workspace
