# Docker build context — keep it small. The image installs the `anchormap` R package from source
# (DESCRIPTION + NAMESPACE + R/ + inst/ + man/), so only those need to be in context. The shims in
# docker/bin/ are COPYed in too. Everything below is irrelevant to the build / would leak artifacts.

# Vendored scaffold — its own git repo, not part of AnchorMap
claude-science-scaffold/

# VCS / planning / validation harness / orchestration (not needed at runtime)
.git/
.gitignore
.agents/
.claude/
validation/
nextflow/

# Machine-specific private configs + dev/run outputs
local/
results/
inst/results/
work/
.nextflow/

# R build artifacts + internal docs (not installed)
*.Rcheck/
*.tar.gz
README.production.md
ANALYSIS_DESIGN.md

# Editor / OS / R session cruft
.DS_Store
.Rhistory
.RData
.Rapp.history
.Rproj.user/
*_cache/
*~
.idea/
AnchorMap.code-workspace
