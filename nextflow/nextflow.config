// AnchorMap — Nextflow config for the container-validation harness.
// Standard profiles: a local docker CI gate + a Google Batch (spot) one-time check. Set the GCP
// project / bucket / network below to your own before using -profile gcp.

params {
  anchormap_container = null                              // set per-profile params file
  smoke_cpus          = 2
  gcp_bucket          = 'gs://mpreuss-projects-usc1'
  project_slug        = 'AnchorMap'
  user                = System.getenv('USER') ?: 'unknown-user'
}

// Default (local) process resources — the workload is tiny.
process {
  executor = 'local'
  cpus     = 1
  memory   = '4 GB'
  time     = '30m'
}

profiles {
  // The CI gate: local docker. Validates ENTRYPOINT [] (no exit-126), procps/ps, and output capture.
  test {
    process.executor = 'local'
    docker.enabled   = true
    workDir          = 'work'
    outputDir        = 'results/anchormap_smoke'
  }

  // The one-time Batch check: the ONLY run that exercises USER-root / GCS-FUSE write perms.
  gcp {
    process {
      executor      = 'google-batch'
      errorStrategy = 'retry'
      maxRetries    = 3
      cache         = 'lenient'
      disk          = '10 GB'
    }
    workDir   = "${params.gcp_bucket}/${params.project_slug}/work/${params.user}"
    outputDir = "${params.gcp_bucket}/${params.project_slug}/results/${params.user}"
    docker.enabled = true
  }
}

google {
  project  = 'lencz-lab-cogent-1'
  location = 'us-central1'
  batch {
    spot       = true   // preemptible VMs (~60-70% cheaper); jobs may be preempted and retried
    network    = 'projects/lencz-lab-cogent-1/global/networks/default'
    subnetwork = 'projects/lencz-lab-cogent-1/regions/us-central1/subnetworks/default'
  }
}
